{
	"name": "dataflow1",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "Excel1",
						"type": "DatasetReference"
					},
					"name": "fact"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "Parquet1",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          Ticket_ID as short,",
				"          Date_Key as short,",
				"          Agent_ID as string,",
				"          Customer_ID as short,",
				"          Channel_ID as short,",
				"          Department_ID as short,",
				"          Issue_Type_ID as short,",
				"          Status_ID as short,",
				"          Shift_ID as short,",
				"          Satisfaction_ID as short,",
				"          First_Response_Time as short,",
				"          Handle_Time as short,",
				"          Resolution_Time as short,",
				"          First_Call_Resolution as boolean,",
				"          Escalation_Flag as boolean,",
				"          Transfer_Count as short,",
				"          Reopen_Count as boolean,",
				"          SLA_Breached as boolean,",
				"          Agent_Utilization as double,",
				"          Occupancy_Rate as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> fact",
				"fact sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          Customer_ID as integer,",
				"          Customer_Name as string,",
				"          Gender as string,",
				"          Age as integer,",
				"          Customer_Segment as string,",
				"          Loyalty_Level as string,",
				"          New_Country as string,",
				"          New_City as string,",
				"          Join_Date as string",
				"     ),",
				"     format: 'parquet',",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}